# EcoTrazabilidad REP - configuración sugerida
# Si ya dejé creada la base PostgreSQL en Render en una entrega anterior,
# aquí solo debo reutilizar la External Database URL de esa misma base.

# Opción recomendada para Render o para conectarme desde mi equipo a la base ya creada
DATABASE_URL=postgresql://USUARIO:CLAVE@HOST_EXTERNO:5432/NOMBRE_BASE
DATABASE_SSL=true

# Opción alternativa solo para desarrollo local con PostgreSQL propio
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_NAME=ley_rep
# DATABASE_SSL=false

PORT=3000
SESSION_SECRET=leyrep123
